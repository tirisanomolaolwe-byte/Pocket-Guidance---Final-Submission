<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".PocketGuidanceApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketGuidance">

        <activity android:name=".ui.activities.ForgotPasswordActivity"
            android:label="Reset Password" />

        <!-- Splash / entry point — theme is required by installSplashScreen() -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PocketGuidance.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.activities.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.activities.SignupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.activities.OnboardingActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.DashboardActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.CategoryActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.AddExpenseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.activities.ViewExpenseActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.BudgetsActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.GoalsActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity android:name=".ui.activities.ReceiptViewActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.EarnActivity"
            android:exported="false" />

        <activity android:name=".ui.activities.ReportsActivity"
            android:exported="false" />

        <!-- FileProvider for camera photo URIs -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        
    </application>
</manifest>
